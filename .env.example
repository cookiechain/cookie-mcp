# Cookie Chain RPC endpoint. Defaults to the public Cookiescan RPC.
COOKIE_RPC_URL=https://rpc.cookiescan.io

# Solana mainnet RPC endpoint. Only needed for the `bridge` tool. The default public endpoint below
# works for reads and light use, but it is heavily rate-limited and unreliable for landing the
# `solana-to-cookie` transfer (that direction sends + confirms on Solana). For real bridging, use a
# dedicated RPC — e.g. Helius (https://helius.dev), Shyft (https://shyft.to),
# or QuickNode (https://quicknode.com); paste your provider URL (with API key) here.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Wallet key for trade/transfer/deploy tools. OPTIONAL — when unset, the server runs in
# read-only mode (read tools work; money-moving tools return a clear "no wallet configured" error).
# Accepts a base58 secret string OR a solana-keygen JSON byte array OR a path to a keypair file.
# NEVER commit a real key. This value is read from the environment only.
COOKIE_PRIVATE_KEY=

# Hard per-trade spend cap, denominated in COOK. The `trade` tool refuses any swap whose input
# is valued above this. Default: 100.
COOKIE_MAX_TRADE_COOK=100

# Default slippage tolerance in basis points (500 = 5%).
COOKIE_SLIPPAGE_BPS=500
